local function findCustomHead(model)
	local head = model:FindFirstChild("Head") or model:FindFirstChild("head")
	if head and head:IsA("BasePart") then return head end
	for _, child in ipairs(model:GetDescendants()) do
		if child:IsA("BasePart") and (string.lower(child.Name) == "head" or string.find(string.lower(child.Name), "head")) then
			return child
		end
	end
	return model:FindFirstChild("HumanoidRootPart")
end

local function isVisible(targetPart, character)
	local origin = camera.CFrame.Position
	local direction = (targetPart.Position - origin).Unit * (targetPart.Position - origin).Magnitude
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.FilterDescendantsInstances = {localPlayer.Character, character, camera}
	raycastParams.IgnoreWater = true
	
	local result = workspace:Raycast(origin, direction, raycastParams)
	return result == nil
end

local function getClosestTargetInFOV()
	local character = localPlayer.Character
	if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end

	local closestTarget = nil
	local shortestDistance = fovRadius
	local centerScreen = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)

	local function checkValidTarget(object, playerOwner)
		if useTeamCheck and playerOwner and playerOwner.Team == localPlayer.Team then return end
		
		if object and object:FindFirstChild("Humanoid") and object.Humanoid.Health > 0 then
			local targetPart = nil
			if targetPartName == "Head" then
				targetPart = findCustomHead(object)
			else
				targetPart = object:FindFirstChild("HumanoidRootPart") or object:FindFirstChild("Torso") or object:FindFirstChild("UpperTorso")
			end
			
			if targetPart then
				if useWallCheck and not isVisible(targetPart, object) then return end
				
				local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
				if onScreen then
					local distanceToCenter = (Vector2.new(screenPos.X, screenPos.Y) - centerScreen).Magnitude
					if distanceToCenter < shortestDistance then
						shortestDistance = distanceToCenter
						closestTarget = targetPart
					end
				end
			end
		end
	end

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= localPlayer and player.Character then
			checkValidTarget(player.Character, player)
		end
	end

	for _, object in ipairs(workspace:GetChildren()) do
		if object:IsA("Model") and object ~= character and not Players:GetPlayerFromCharacter(object) then
			checkValidTarget(object, nil)
		end
	end

	return closestTarget
end

local function updateAimbot()
	if not isAimbotEnabled then return end
	
	local targetPart = getClosestTargetInFOV()
	if targetPart then
		local currentCFrame = camera.CFrame
		local targetCFrame = CFrame.new(currentCFrame.Position, targetPart.Position)
		camera.CFrame = currentCFrame:Lerp(targetCFrame, smoothSpeed)
	end
end

local function updateESP()
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= localPlayer and player.Character then
			local char = player.Character
			local highlight = char:FindFirstChild("ESPHighlight")
			if isAimbotEnabled then
				if useTeamCheck and player.Team == localPlayer.Team then
					if highlight then highlight:Destroy() end
				else
					if not highlight then
						highlight = Instance.new("Highlight")
						highlight.Name = "ESPHighlight"
						highlight.FillColor = Color3.fromRGB(255, 50, 50)
						highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
						highlight.FillTransparency = 0.5
						highlight.OutlineTransparency = 0
						highlight.Adornee = char
						highlight.Parent = char
					end
				end
			else
				if highlight then highlight:Destroy() end
			end
		end
	end
	
	for _, object in ipairs(workspace:GetChildren()) do
		if object:IsA("Model") and object:FindFirstChild("Humanoid") and not Players:GetPlayerFromCharacter(object) then
			local highlight = object:FindFirstChild("ESPHighlight")
			if isAimbotEnabled then
				if not highlight then
					highlight = Instance.new("Highlight")
					highlight.Name = "ESPHighlight"
					highlight.FillColor = Color3.fromRGB(255, 150, 0)
					highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
					highlight.FillTransparency = 0.5
					highlight.OutlineTransparency = 0
					highlight.Adornee = object
					highlight.Parent = object
				end
			else
				if highlight then highlight:Destroy() end
			end
		end
	end
end

local function toggleAimbot()
	isAimbotEnabled = not isAimbotEnabled
	if isAimbotEnabled then
		toggleButton.Text = "Aimbot: ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(70, 160, 70)
		toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
		fovCircle.Visible = true
	else
		isAimbotEnabled = false
		toggleButton.Text = "Aimbot: OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(230, 230, 230)
		toggleButton.TextColor3 = Color3.fromRGB(50, 50, 50)
		fovCircle.Visible = false
	end
end

local function togglePart()
	if targetPartName == "Head" then
		targetPartName = "HumanoidRootPart"
		partButton.Text = "Target: body"
	else
		targetPartName = "Head"
		partButton.Text = "Target: head"
	end
end

local function toggleButtonState(btn, stateVar, textOn, textOff)
	if stateVar then
		btn.Text = textOn
		btn.BackgroundColor3 = Color3.fromRGB(70, 160, 70)
		btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	else
		btn.Text = textOff
		btn.BackgroundColor3 = Color3.fromRGB(230, 230, 230)
		btn.TextColor3 = Color3.fromRGB(50, 50, 50)
	end
end

